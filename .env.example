# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager
POSTGRES_PORT=5433

# Backend
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taskmanager
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-min-32
FRONTEND_URL=http://localhost
PORT=3000
NODE_ENV=production

# Frontend
FRONTEND_PORT=80
VITE_API_URL=/api
